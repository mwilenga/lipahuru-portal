{
  "name": "portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint",
    "pm2:start:sandbox": "pm2 start ecosystem.config.cjs --only lipahuru-portal-sandbox",
    "pm2:start:prod": "pm2 start ecosystem.config.cjs --only lipahuru-portal-prod",
    "pm2:restart:sandbox": "pm2 restart lipahuru-portal-sandbox --update-env",
    "pm2:restart:prod": "pm2 restart lipahuru-portal-prod --update-env",
    "pm2:stop:sandbox": "pm2 stop lipahuru-portal-sandbox",
    "pm2:stop:prod": "pm2 stop lipahuru-portal-prod",
    "pm2:logs:sandbox": "pm2 logs lipahuru-portal-sandbox",
    "pm2:logs:prod": "pm2 logs lipahuru-portal-prod",
    "deploy:sandbox": "bash deploy/deploy-sandbox.sh",
    "deploy:prod": "bash deploy/deploy-prod.sh"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sweetalert2": "^11.26.25",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/xlsx": "^0.0.35",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
